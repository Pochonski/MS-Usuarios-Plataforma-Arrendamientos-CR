PORT=3000
NODE_ENV=development

# Azure SQL Database
DB_HOST=your-server.database.windows.net
DB_PORT=1433
DB_NAME=usuarios_db
DB_USER=your_username
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# Azure APIM
APIM_SUBSCRIPTION_KEY=your_apim_subscription_key
APIM_CLIENT_CERT_THUMBPRINT=your_client_cert_thumbprint
APIM_VALIDATE_CLIENT_CERT=false
APIM_INTERNAL_API_URL=

# Google OAuth (para login con Google)
# Solo se necesita el Client ID. NO incluyas el Client Secret: el backend
# usa verifyIdToken() (verificación de firma + aud), no el flujo de código.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID =your_google_client_id.apps.googleusercontent.com
# Rate Limiting (requests per window)
RL_WINDOW_MINUTES=15
RL_AUTH_MAX=5
RL_READ_MAX=200
RL_WRITE_MAX=50
RL_GENERAL_MAX=100